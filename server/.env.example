# ──────────────────────────────────────────────────────────────────────────────
# server/.env.example — copia este archivo como .env y rellena los valores
# NUNCA subas .env con valores reales a Git
# ──────────────────────────────────────────────────────────────────────────────

# ─── Payphone (credenciales en https://developer.payphone.app) ────────────────
PAYPHONE_BASE_URL=https://pay.payphonetodoesposible.com
PAYPHONE_TOKEN=
PAYPHONE_CLIENT_ID=
PAYPHONE_SECRET=
PAYPHONE_ENCODING_PASSWORD=

# URLs de retorno — usar dominio real en producción
PAYPHONE_RESPONSE_URL=https://vienainternacionaluio.com/payment-response
PAYPHONE_CANCELLATION_URL=https://vienainternacionaluio.com/habitaciones
ADMIN_PAYMENT_RESPONSE_URL=https://vienainternacionaluio.com/payment-response-admin

# ─── Sitio ────────────────────────────────────────────────────────────────────
SITE_BASE_URL=https://vienainternacionaluio.com
FRONTEND_URL=https://vienainternacionaluio.com

# ─── Servidor ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── SMTP (Titan Mail) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.titan.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=
SMTP_PASS=
ADMIN_EMAIL=
